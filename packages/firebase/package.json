{
  "name": "@unbogi/firebase",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": "22"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsup",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "firebase emulators:exec \"vitest run -c vitest.integration.config.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "resend": "^6.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@unbogi/contracts": "file:../contracts",
    "@vitest/coverage-v8": "^2.1.9",
    "firebase-functions-test": "^3.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^2.1.0"
  }
}
